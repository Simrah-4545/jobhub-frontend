# JobHub Backend - Environment Variables
# Copy to .env and fill in your actual values

# MongoDB Connection (FREE TIER: mongodb.com/atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/jobhub?retryWrites=true&w=majority

# Razorpay (India/UAE Payments)
# Register at: https://razorpay.com
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Stripe (USA/Canada Payments)
# Register at: https://stripe.com
STRIPE_PUBLIC_KEY=pk_test_your_public_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email Service (for notifications)
# Use: SendGrid, Gmail, or Brevo (FREE tier available)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your_app_password

# Server Configuration
NODE_ENV=production
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=https://jobhub.vercel.app

# Optional: Indeed API Key
# Register at: https://opensource.indeedeng.io/api-details/
INDEED_API_KEY=your_indeed_api_key

# Optional: LinkedIn API (complex - use web scraping alternative)
# Consider using: Puppeteer + custom scraper instead

# Optional: AWS S3 (for storing user documents/resumes)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=jobhub-bucket